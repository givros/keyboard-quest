{
  "rules": {
    "keyboardQuest": {
      "leaderboard": {
        ".read": true,
        "$uid": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.hasChild('nickname') && newData.child('nickname').isString() && newData.child('nickname').val().length <= 18 && (!newData.child('total').exists() || newData.child('total').isNumber())"
        }
      }
    }
  }
}
